---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="TDEE Calculator"
  description="This calculator estimates the Total Daily Energy Expenditure (TDEE) of a person based on their age, physical characteristics, and activity level."
  canonical="https://tdee.lab/tdee-calculator/"
>
  <h1>TDEE Calculator</h1>
  <p class="page-description">This calculator can be used to estimate your Total Daily Energy Expenditure (TDEE).</p>

  <!-- Unit Tabs -->
  <div class="unit-tabs">
    <button class="unit-tab active" data-unit="standard">US Units</button>
    <button class="unit-tab" data-unit="metric">Metric Units</button>
  </div>

  <!-- Calculator Form -->
  <div class="calc-form">
    <table class="form-table">
      <tr>
        <td>Age</td>
        <td>
          <input type="number" id="input-age" class="form-input form-input-small" value="25" min="18" max="80" />
          <span class="form-hint">ages 18 - 80</span>
        </td>
      </tr>
      <tr>
        <td>Gender</td>
        <td>
          <div class="radio-group">
            <label class="radio-label">
              <input type="radio" name="gender" value="male" checked /> Male
            </label>
            <label class="radio-label">
              <input type="radio" name="gender" value="female" /> Female
            </label>
          </div>
        </td>
      </tr>
    </table>

    <!-- US Units -->
    <table class="form-table" id="standard-inputs">
      <tr>
        <td>Height</td>
        <td>
          <input type="number" id="input-height-ft" class="form-input form-input-small" value="5" min="3" max="8" />
          <span class="form-hint">feet</span>
          <input type="number" id="input-height-in" class="form-input form-input-small" value="10" min="0" max="11" style="margin-left: 8px;" />
          <span class="form-hint">inches</span>
        </td>
      </tr>
      <tr>
        <td>Weight</td>
        <td>
          <input type="number" id="input-weight-lbs" class="form-input form-input-small" value="165" min="66" max="660" />
          <span class="form-hint">pounds</span>
        </td>
      </tr>
    </table>

    <!-- Metric Units -->
    <table class="form-table" id="metric-inputs" style="display: none;">
      <tr>
        <td>Height</td>
        <td>
          <input type="number" id="input-height-cm" class="form-input form-input-small" value="170" min="100" max="260" />
          <span class="form-hint">cm</span>
        </td>
      </tr>
      <tr>
        <td>Weight</td>
        <td>
          <input type="number" id="input-weight-kg" class="form-input form-input-small" value="70" min="30" max="300" />
          <span class="form-hint">kg</span>
        </td>
      </tr>
    </table>

    <table class="form-table">
      <tr>
        <td>Activity</td>
        <td>
          <select id="input-activity" class="form-select">
            <option value="1.2">Sedentary: little or no exercise</option>
            <option value="1.375">Light: exercise 1-3 times/week</option>
            <option value="1.55" selected>Moderate: exercise 3-5 times/week</option>
            <option value="1.725">Active: daily exercise or intense exercise 6-7 times/week</option>
            <option value="1.9">Very Active: very intense exercise daily, or physical job</option>
          </select>
        </td>
      </tr>
      <tr>
        <td></td>
        <td>
          <button class="settings-toggle" id="settings-toggle">+ Settings</button>
          <div class="settings-content" id="settings-content">
            <div style="margin-bottom: 12px;">
              <strong>BMR estimation formula:</strong>
            </div>
            <div class="radio-group">
              <label class="radio-label">
                <input type="radio" name="formula" value="mifflin" checked /> Mifflin St Jeor
              </label>
              <label class="radio-label">
                <input type="radio" name="formula" value="katch" /> Katch-McArdle
              </label>
            </div>
            <div id="body-fat-input" style="display: none; margin-top: 12px;">
              <label class="radio-label">
                Body Fat: <input type="number" id="input-body-fat" class="form-input form-input-small" value="20" min="1" max="60" style="margin-left: 8px;" />
                <span class="form-hint">%</span>
              </label>
            </div>
          </div>
        </td>
      </tr>
      <tr>
        <td></td>
        <td>
          <div class="btn-group">
            <button class="btn-calculate" id="btn-calculate">Calculate</button>
            <button class="btn-clear" id="btn-clear">Clear</button>
          </div>
        </td>
      </tr>
    </table>
  </div>

  <ul class="activity-info">
    <li><strong>Exercise:</strong> 15-30 minutes of elevated heart rate activity.</li>
    <li><strong>Intense exercise:</strong> 45-120 minutes of elevated heart rate activity.</li>
    <li><strong>Very intense exercise:</strong> 2+ hours of elevated heart rate activity.</li>
  </ul>

  <!-- Results Section -->
  <div class="results-section" id="results-section" style="display: none;">
    <h2>Results</h2>

    <div class="result-card">
      <div class="result-label">Total Daily Energy Expenditure (TDEE)</div>
      <div>
        <span class="result-value" id="result-tdee">--</span>
        <span class="result-unit">calories/day</span>
      </div>
    </div>

    <div class="result-card">
      <div class="result-label">Basal Metabolic Rate (BMR)</div>
      <div>
        <span class="result-value" id="result-bmr" style="font-size: 22px;">--</span>
        <span class="result-unit">calories/day</span>
      </div>
    </div>

    <h3 style="font-size: 16px; font-weight: 600; margin: 20px 0 12px;">Calorie Goals</h3>
    <table class="goals-table">
      <thead>
        <tr>
          <th>Goal</th>
          <th>Calories</th>
          <th>Change</th>
          <th>Rate</th>
        </tr>
      </thead>
      <tbody id="goals-body">
      </tbody>
    </table>

    <h3 style="font-size: 16px; font-weight: 600; margin: 20px 0 12px;">Macronutrient Split</h3>
    <div class="macro-grid">
      <div class="macro-card macro-protein">
        <div class="macro-name">Protein</div>
        <div class="macro-grams"><span id="macro-protein-g">--</span>g</div>
        <div class="macro-kcal"><span id="macro-protein-kcal">--</span> kcal</div>
      </div>
      <div class="macro-card macro-fat">
        <div class="macro-name">Fat</div>
        <div class="macro-grams"><span id="macro-fat-g">--</span>g</div>
        <div class="macro-kcal"><span id="macro-fat-kcal">--</span> kcal</div>
      </div>
      <div class="macro-card macro-carbs">
        <div class="macro-name">Carbs</div>
        <div class="macro-grams"><span id="macro-carbs-g">--</span>g</div>
        <div class="macro-kcal"><span id="macro-carbs-kcal">--</span> kcal</div>
      </div>
    </div>
    <div class="macro-bar">
      <div class="macro-bar-protein" id="bar-protein" style="width: 33%"></div>
      <div class="macro-bar-fat" id="bar-fat" style="width: 33%"></div>
      <div class="macro-bar-carbs" id="bar-carbs" style="width: 34%"></div>
    </div>
    <div class="macro-bar-labels">
      <span id="macro-pct-protein">33%</span>
      <span id="macro-pct-fat">33%</span>
      <span id="macro-pct-carbs">34%</span>
    </div>

    <h3 style="font-size: 16px; font-weight: 600; margin: 20px 0 12px;">BMI Status</h3>
    <div class="bmi-display">
      <span class="bmi-value" id="result-bmi">--</span>
      <span class="bmi-category" id="result-bmi-cat">--</span>
    </div>
    <div class="bmi-bar">
      <div class="bmi-marker" id="bmi-marker" style="left: 50%"></div>
    </div>
    <div class="bmi-labels">
      <span>Underweight</span>
      <span>Normal</span>
      <span>Overweight</span>
      <span>Obese</span>
    </div>
  </div>

  <script>
    import '../../scripts/calculator';
  </script>
</Layout>

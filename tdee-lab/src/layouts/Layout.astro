---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  title = "TDEE Calculator",
  description = "This calculator estimates the Total Daily Energy Expenditure (TDEE) of a person based on their age, physical characteristics, and activity level.",
  canonical = "https://tdee.lab"
} = Astro.props;

const siteName = "TDEE Lab";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content={siteName} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content={siteName} />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": siteName,
      "url": canonical,
      "description": description,
      "applicationCategory": "HealthApplication",
      "operatingSystem": "Web",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
    })} />

    <script is:inline>
      // Dark mode initialization - runs before page renders
      (function() {
        const savedTheme = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (savedTheme === 'dark' || (!savedTheme && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body>
    <!-- Top Navigation Bar -->
    <div class="top-nav">
      <div class="top-nav-inner">
        <a href="/tdee-calculator/" class="top-nav-item">Fitness & Health</a>
        <a href="/math-calculator/" class="top-nav-item">Math</a>
        <a href="/financial-calculator/" class="top-nav-item">Financial</a>
        <a href="/other-calculator/" class="top-nav-item">Other</a>
      </div>
    </div>

    <div class="header">
      <div class="header-inner">
        <a href="/" class="logo">
          <svg width="30" height="30" viewBox="0 0 30 30" fill="none">
            <rect width="30" height="30" rx="7.5" fill="url(#logo-grad)"/>
            <path d="M8 10.5h14" stroke="white" stroke-width="2.4" stroke-linecap="round"/>
            <path d="M15 10.5v11" stroke="white" stroke-width="2.4" stroke-linecap="round"/>
            <path d="M11 16l4 3.5 4-3.5" stroke="rgba(255,255,255,0.45)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="22" cy="8" r="2" fill="rgba(255,255,255,0.3)"/>
            <defs>
              <linearGradient id="logo-grad" x1="0" y1="0" x2="30" y2="30">
                <stop stop-color="#4F46E5"/>
                <stop offset="1" stop-color="#7C3AED"/>
              </linearGradient>
            </defs>
          </svg>
          <span>{siteName}</span>
        </a>
        <nav class="header-nav">
          <a href="/tdee-calculator/">Calculator</a>
          <a href="/what-is-tdee/">What is TDEE</a>
          <a href="/bmr-vs-tdee/">BMR vs TDEE</a>
          <button id="theme-toggle" class="theme-toggle" aria-label="Toggle dark mode">
            <svg class="sun-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="5"></circle>
              <line x1="12" y1="1" x2="12" y2="3"></line>
              <line x1="12" y1="21" x2="12" y2="23"></line>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
              <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
              <line x1="1" y1="12" x2="3" y2="12"></line>
              <line x1="21" y1="12" x2="23" y2="12"></line>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
              <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
            </svg>
            <svg class="moon-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none;">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg>
          </button>
        </nav>
      </div>
    </div>

    <div class="main-container">
      <div class="content-area">
        <slot />
      </div>
      <aside class="sidebar">
        <div class="sidebar-box">
          <h3>Fitness & Health</h3>
          <ul>
            <li><a href="/tdee-calculator/">TDEE Calculator</a></li>
            <li><a href="/what-is-tdee/">What is TDEE</a></li>
            <li><a href="/bmr-vs-tdee/">BMR vs TDEE</a></li>
          </ul>
        </div>
        <div class="sidebar-box">
          <h3>Math Calculators</h3>
          <ul>
            <li><a href="/math-calculator/">Basic Math</a></li>
            <li><a href="/math-calculator/#scientific">Scientific</a></li>
            <li><a href="/math-calculator/#fraction">Fraction</a></li>
            <li><a href="/math-calculator/#percentage">Percentage</a></li>
          </ul>
        </div>
        <div class="sidebar-box">
          <h3>Financial</h3>
          <ul>
            <li><a href="/financial-calculator/#mortgage">Mortgage</a></li>
            <li><a href="/financial-calculator/#loan">Loan</a></li>
            <li><a href="/financial-calculator/#investment">Investment</a></li>
            <li><a href="/financial-calculator/#retirement">Retirement</a></li>
          </ul>
        </div>
        <div class="sidebar-box">
          <h3>Other Tools</h3>
          <ul>
            <li><a href="/other-calculator/#date-time">Date & Time</a></li>
            <li><a href="/other-calculator/#conversion">Conversion</a></li>
            <li><a href="/other-calculator/#utility">Utility</a></li>
          </ul>
        </div>
      </aside>
    </div>

    <footer class="footer">
      <div class="footer-inner">
        <p>&copy; {new Date().getFullYear()} {siteName}. All rights reserved.</p>
      </div>
    </footer>

    <!-- Dark Mode Script -->
    <script is:inline>
      const themeToggle = document.getElementById('theme-toggle');
      const sunIcon = themeToggle?.querySelector('.sun-icon');
      const moonIcon = themeToggle?.querySelector('.moon-icon');

      function updateThemeUI() {
        const isDark = document.documentElement.classList.contains('dark');
        if (sunIcon && moonIcon) {
          sunIcon.style.display = isDark ? 'none' : 'block';
          moonIcon.style.display = isDark ? 'block' : 'none';
        }
      }

      themeToggle?.addEventListener('click', () => {
        document.documentElement.classList.toggle('dark');
        const isDark = document.documentElement.classList.contains('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
        updateThemeUI();
      });

      updateThemeUI();
    </script>

    <!-- AI Chat Widget -->
    <script>
      import { initAIWidget } from '../scripts/ai-chat-widget';
      document.addEventListener('DOMContentLoaded', initAIWidget);
    </script>
  </body>
</html>
